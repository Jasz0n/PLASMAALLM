{
  "components": {
    "schemas": {
      "Artifact": {
        "description": "Reference to a supporting file (design, photo, dataset, code).\n\nThe core never stores blobs; ``uri`` points into the platform's\nstorage and ``sha256`` pins the exact bytes for reproducibility.",
        "properties": {
          "media_type": {
            "default": "application/octet-stream",
            "title": "Media Type",
            "type": "string"
          },
          "name": {
            "title": "Name",
            "type": "string"
          },
          "sha256": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Sha256"
          },
          "uri": {
            "title": "Uri",
            "type": "string"
          }
        },
        "required": [
          "name",
          "uri"
        ],
        "title": "Artifact",
        "type": "object"
      },
      "ClaimRequest": {
        "properties": {
          "contributor": {
            "maxLength": 200,
            "minLength": 1,
            "title": "Contributor",
            "type": "string"
          }
        },
        "required": [
          "contributor"
        ],
        "title": "ClaimRequest",
        "type": "object"
      },
      "ConceptSummary": {
        "properties": {
          "confidence": {
            "title": "Confidence",
            "type": "number"
          },
          "evidence_count": {
            "title": "Evidence Count",
            "type": "integer"
          },
          "name": {
            "title": "Name",
            "type": "string"
          },
          "status": {
            "title": "Status",
            "type": "string"
          }
        },
        "required": [
          "name",
          "confidence",
          "status",
          "evidence_count"
        ],
        "title": "ConceptSummary",
        "type": "object"
      },
      "DocumentSubmission": {
        "description": "POST /documents body \u2014 one raw human explanation stream.",
        "properties": {
          "context": {
            "default": "general",
            "maxLength": 100,
            "title": "Context",
            "type": "string"
          },
          "name": {
            "maxLength": 300,
            "minLength": 1,
            "title": "Name",
            "type": "string"
          },
          "text": {
            "maxLength": 500000,
            "minLength": 1,
            "title": "Text",
            "type": "string"
          }
        },
        "required": [
          "name",
          "text"
        ],
        "title": "DocumentSubmission",
        "type": "object"
      },
      "EvidenceSubmission": {
        "description": "POST /evidence body \u2014 a package without an id (the core mints it).\n\nSize caps (M50): generous for honest contributions, hostile to\npayload abuse. Artifacts are references, never blobs \u2014 the platform\nstores files.",
        "properties": {
          "artifacts": {
            "items": {
              "$ref": "#/components/schemas/Artifact"
            },
            "maxItems": 32,
            "title": "Artifacts",
            "type": "array"
          },
          "claim": {
            "maxLength": 2000,
            "minLength": 1,
            "title": "Claim",
            "type": "string"
          },
          "concept": {
            "maxLength": 200,
            "minLength": 1,
            "title": "Concept",
            "type": "string"
          },
          "contributor": {
            "maxLength": 200,
            "minLength": 1,
            "title": "Contributor",
            "type": "string"
          },
          "environment": {
            "additionalProperties": {
              "type": "string"
            },
            "title": "Environment",
            "type": "object"
          },
          "kind": {
            "default": "experiment",
            "enum": [
              "experiment",
              "replication",
              "paper",
              "transcript",
              "debate",
              "observation"
            ],
            "title": "Kind",
            "type": "string"
          },
          "measurements": {
            "additionalProperties": true,
            "title": "Measurements",
            "type": "object"
          },
          "outcome": {
            "enum": [
              "supported",
              "challenged",
              "inconclusive"
            ],
            "title": "Outcome",
            "type": "string"
          },
          "related_concepts": {
            "items": {
              "type": "string"
            },
            "maxItems": 32,
            "title": "Related Concepts",
            "type": "array"
          },
          "replicates": {
            "anyOf": [
              {
                "maxLength": 200,
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Replicates"
          },
          "reproduction_steps": {
            "items": {
              "type": "string"
            },
            "maxItems": 64,
            "title": "Reproduction Steps",
            "type": "array"
          }
        },
        "required": [
          "claim",
          "concept",
          "contributor",
          "outcome"
        ],
        "title": "EvidenceSubmission",
        "type": "object"
      },
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "title": "Detail",
            "type": "array"
          }
        },
        "title": "HTTPValidationError",
        "type": "object"
      },
      "ResolveRequest": {
        "properties": {
          "packages": {
            "items": {
              "$ref": "#/components/schemas/EvidenceSubmission"
            },
            "maxItems": 16,
            "title": "Packages",
            "type": "array"
          }
        },
        "required": [
          "packages"
        ],
        "title": "ResolveRequest",
        "type": "object"
      },
      "TeacherKelSessionResponse": {
        "description": "Active Teacher pause session between Researcher and KEL loop.",
        "properties": {
          "exported_at": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Exported At"
          },
          "opened_at": {
            "title": "Opened At",
            "type": "string"
          },
          "pending_briefs": {
            "title": "Pending Briefs",
            "type": "integer"
          },
          "resume_flag": {
            "title": "Resume Flag",
            "type": "string"
          },
          "resumed_at": {
            "anyOf": [
              {
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Resumed At"
          },
          "run_dir": {
            "title": "Run Dir",
            "type": "string"
          },
          "session_id": {
            "title": "Session Id",
            "type": "string"
          },
          "status": {
            "title": "Status",
            "type": "string"
          },
          "student_exports": {
            "title": "Student Exports",
            "type": "integer"
          },
          "total_briefs": {
            "title": "Total Briefs",
            "type": "integer"
          }
        },
        "required": [
          "session_id",
          "run_dir",
          "status",
          "pending_briefs",
          "total_briefs",
          "student_exports",
          "opened_at",
          "resume_flag"
        ],
        "title": "TeacherKelSessionResponse",
        "type": "object"
      },
      "ValidationError": {
        "properties": {
          "ctx": {
            "title": "Context",
            "type": "object"
          },
          "input": {
            "title": "Input"
          },
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "title": "Location",
            "type": "array"
          },
          "msg": {
            "title": "Message",
            "type": "string"
          },
          "type": {
            "title": "Error Type",
            "type": "string"
          }
        },
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError",
        "type": "object"
      },
      "VisualApprovalRequest": {
        "description": "POST body for approving or rejecting one brief.",
        "properties": {
          "approved": {
            "default": true,
            "title": "Approved",
            "type": "boolean"
          },
          "approved_by": {
            "default": "teacher-ui",
            "title": "Approved By",
            "type": "string"
          },
          "include_diagram": {
            "default": true,
            "title": "Include Diagram",
            "type": "boolean"
          },
          "include_experiment": {
            "default": true,
            "title": "Include Experiment",
            "type": "boolean"
          },
          "max_images": {
            "default": 2,
            "maximum": 6.0,
            "minimum": 0.0,
            "title": "Max Images",
            "type": "integer"
          },
          "max_questions": {
            "default": 3,
            "maximum": 10.0,
            "minimum": 0.0,
            "title": "Max Questions",
            "type": "integer"
          },
          "review_note": {
            "default": "",
